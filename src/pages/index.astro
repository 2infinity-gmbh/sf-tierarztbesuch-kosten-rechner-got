---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Tierarztkosten berechnen nach GOT 2022"
  description="Berechnen Sie die Kosten für Ihren Tierarztbesuch mit unserem kostenlosen Rechner. Basierend auf der aktuellen Gebührenordnung für Tierärzte (GOT) 2022."
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Hero Section -->
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        Tierarztkosten Rechner
      </h1>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Berechnen Sie vorab, was Ihr Tierarztbesuch kosten wird.
        Basierend auf der aktuellen Gebührenordnung für Tierärzte (GOT) 2022.
      </p>
    </div>

    <!-- Ad Space Placeholder -->
    <div class="mb-8 p-4 bg-gray-100 border-2 border-dashed border-gray-300 rounded-lg text-center text-gray-500">
      [Werbefläche Header - 728x90]
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Calculator Main -->
      <div class="lg:col-span-2">
        <div class="bg-white rounded-lg shadow-lg p-6 md:p-8">
          <h2 class="text-2xl font-bold mb-6">Kosten berechnen</h2>

          <form id="calculator-form" class="space-y-6">
            <!-- Tierart -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">
                Tierart
              </label>
              <select id="animal-type" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent">
                <option value="dog">Hund</option>
                <option value="cat">Katze</option>
                <option value="rabbit">Kaninchen</option>
                <option value="bird">Vogel</option>
                <option value="horse">Pferd</option>
              </select>
            </div>

            <!-- Behandlungsart -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">
                Behandlung
              </label>
              <select id="treatment-type" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent">
                <option value="examination">Allgemeine Untersuchung</option>
                <option value="vaccination">Impfung (pro Impfung)</option>
                <option value="castration">Kastration</option>
                <option value="dental">Zahnbehandlung</option>
                <option value="emergency">Notfallbehandlung</option>
                <option value="xray">Röntgenuntersuchung</option>
              </select>
            </div>

            <!-- GOT Satz -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">
                GOT-Satz
              </label>
              <div class="space-y-2">
                <label class="flex items-center">
                  <input type="radio" name="got-rate" value="1" checked class="mr-2">
                  <span>Einfacher Satz (1x) - Routinebehandlung</span>
                </label>
                <label class="flex items-center">
                  <input type="radio" name="got-rate" value="2" class="mr-2">
                  <span>Zweifacher Satz (2x) - Normalfall</span>
                </label>
                <label class="flex items-center">
                  <input type="radio" name="got-rate" value="3" class="mr-2">
                  <span>Dreifacher Satz (3x) - Schwieriger Fall/Notdienst</span>
                </label>
              </div>
            </div>

            <!-- Notdienst -->
            <div>
              <label class="flex items-center">
                <input type="checkbox" id="emergency-service" class="mr-2">
                <span class="text-sm font-medium text-gray-700">Notdienst (außerhalb regulärer Sprechzeiten)</span>
              </label>
            </div>

            <button type="button" id="calculate-btn" class="w-full bg-primary-600 text-white py-3 px-6 rounded-lg hover:bg-primary-700 transition font-semibold">
              Kosten berechnen
            </button>
          </form>

          <!-- Results -->
          <div id="results" class="hidden mt-8 p-6 bg-primary-50 rounded-lg border-2 border-primary-200">
            <h3 class="text-xl font-bold mb-4">Geschätzte Kosten:</h3>
            <div class="space-y-2">
              <div class="flex justify-between text-lg">
                <span>Grundgebühr:</span>
                <span id="base-cost" class="font-semibold">-</span>
              </div>
              <div class="flex justify-between text-lg">
                <span>GOT-Satz:</span>
                <span id="rate-multiplier" class="font-semibold">-</span>
              </div>
              <div id="emergency-fee-row" class="hidden flex justify-between text-lg">
                <span>Notdienstzuschlag:</span>
                <span id="emergency-fee" class="font-semibold">-</span>
              </div>
              <div class="border-t-2 border-primary-300 mt-2 pt-2">
                <div class="flex justify-between text-2xl font-bold text-primary-700">
                  <span>Gesamt:</span>
                  <span id="total-cost">-</span>
                </div>
              </div>
            </div>
            <p class="mt-4 text-sm text-gray-600">
              <strong>Hinweis:</strong> Dies ist eine Schätzung. Die tatsächlichen Kosten können je nach Aufwand,
              zusätzlichen Leistungen und Medikamenten variieren.
            </p>
          </div>
        </div>

        <!-- Info Section -->
        <div class="mt-8 bg-blue-50 border-l-4 border-blue-500 p-6 rounded">
          <h3 class="font-bold text-lg mb-2">Was ist die GOT?</h3>
          <p class="text-gray-700">
            Die Gebührenordnung für Tierärzte (GOT) regelt seit November 2022 bundesweit einheitlich,
            welche Kosten Tierärzte für ihre Leistungen berechnen dürfen. Jede Behandlung hat einen
            Mindestpreis (einfacher Satz) und kann je nach Aufwand bis zum dreifachen Satz berechnet werden.
          </p>
          <a href="/artikel/tierarztkosten-rechner-was-kostet-tierarztbesuch" class="text-primary-600 hover:text-primary-700 font-medium mt-2 inline-block">
            Mehr über Tierarztkosten erfahren →
          </a>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="lg:col-span-1">
        <!-- Ad Space -->
        <div class="mb-6 p-4 bg-gray-100 border-2 border-dashed border-gray-300 rounded-lg text-center text-gray-500">
          [Sidebar Ad - 300x250]
        </div>

        <!-- Quick Info -->
        <div class="bg-white rounded-lg shadow-lg p-6 mb-6">
          <h3 class="font-bold text-lg mb-4">Aktuelle GOT 2022</h3>
          <ul class="space-y-3 text-sm">
            <li class="flex items-start">
              <span class="text-primary-600 mr-2">✓</span>
              <span>Gilt seit 22. November 2022</span>
            </li>
            <li class="flex items-start">
              <span class="text-primary-600 mr-2">✓</span>
              <span>Preise um 20-65% gestiegen</span>
            </li>
            <li class="flex items-start">
              <span class="text-primary-600 mr-2">✓</span>
              <span>Bundesweit einheitlich</span>
            </li>
            <li class="flex items-start">
              <span class="text-primary-600 mr-2">✓</span>
              <span>Rechtlich bindend</span>
            </li>
          </ul>
        </div>

        <!-- Recent Articles -->
        <div class="bg-white rounded-lg shadow-lg p-6">
          <h3 class="font-bold text-lg mb-4">Ratgeber</h3>
          <ul class="space-y-3">
            <li>
              <a href="/artikel/tierarztkosten-rechner-was-kostet-tierarztbesuch" class="text-primary-600 hover:text-primary-700 text-sm">
                Was kostet der Tierarztbesuch wirklich?
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <script>
    // Treatment costs based on GOT 2022 (base rates in EUR)
    const treatmentCosts = {
      examination: 23.62,
      vaccination: 11.50,
      castration: 160.00, // varies by animal
      dental: 89.00,
      emergency: 58.00,
      xray: 45.00,
    };

    const calculateBtn = document.getElementById('calculate-btn');
    const resultsDiv = document.getElementById('results');

    calculateBtn?.addEventListener('click', () => {
      const treatmentType = (document.getElementById('treatment-type') as HTMLSelectElement).value;
      const gotRate = parseFloat((document.querySelector('input[name="got-rate"]:checked') as HTMLInputElement).value);
      const isEmergency = (document.getElementById('emergency-service') as HTMLInputElement).checked;

      const baseCost = treatmentCosts[treatmentType as keyof typeof treatmentCosts] || 0;
      const costWithRate = baseCost * gotRate;
      const emergencyFee = isEmergency ? costWithRate * 0.5 : 0; // 50% surcharge
      const totalCost = costWithRate + emergencyFee;

      // Update UI
      document.getElementById('base-cost')!.textContent = `${baseCost.toFixed(2)} €`;
      document.getElementById('rate-multiplier')!.textContent = `${gotRate}x = ${costWithRate.toFixed(2)} €`;

      const emergencyRow = document.getElementById('emergency-fee-row');
      if (isEmergency) {
        emergencyRow?.classList.remove('hidden');
        document.getElementById('emergency-fee')!.textContent = `${emergencyFee.toFixed(2)} €`;
      } else {
        emergencyRow?.classList.add('hidden');
      }

      document.getElementById('total-cost')!.textContent = `${totalCost.toFixed(2)} €`;

      resultsDiv?.classList.remove('hidden');
      resultsDiv?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    });
  </script>
</BaseLayout>
