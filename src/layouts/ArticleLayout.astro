---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  description: string;
  publishDate: string;
  author?: string;
}

const { title, description, publishDate, author = "Redaktion" } = Astro.props;
const formattedDate = new Date(publishDate).toLocaleDateString('de-DE', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<BaseLayout title={title} description={description}>
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Article Header -->
    <header class="mb-8">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        {title}
      </h1>
      <div class="flex items-center text-gray-600 text-sm">
        <span>{author}</span>
        <span class="mx-2">•</span>
        <time datetime={publishDate}>{formattedDate}</time>
      </div>
    </header>

    <!-- Ad Space -->
    <div class="mb-8 p-4 bg-gray-100 border-2 border-dashed border-gray-300 rounded-lg text-center text-gray-500">
      [In-Content Ad - 728x90]
    </div>

    <!-- Article Content -->
    <div class="prose prose-lg max-w-none prose-headings:font-bold prose-h2:text-3xl prose-h2:mt-8 prose-h2:mb-4 prose-h3:text-2xl prose-h3:mt-6 prose-h3:mb-3 prose-p:text-gray-700 prose-p:leading-relaxed prose-ul:text-gray-700 prose-strong:text-gray-900 prose-a:text-primary-600 prose-a:no-underline hover:prose-a:underline">
      <slot />
    </div>

    <!-- Article Footer -->
    <div class="mt-12 pt-8 border-t border-gray-200">
      <div class="bg-blue-50 border-l-4 border-blue-500 p-6 rounded">
        <h3 class="font-bold text-lg mb-2">Kosten berechnen</h3>
        <p class="text-gray-700 mb-4">
          Nutzen Sie unseren kostenlosen Rechner, um die Kosten für Ihren Tierarztbesuch vorab zu kalkulieren.
        </p>
        <a href="/" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg hover:bg-primary-700 transition font-semibold">
          Zum Kostenrechner
        </a>
      </div>
    </div>

    <!-- Related Articles -->
    <div class="mt-8">
      <h3 class="text-2xl font-bold mb-4">Weitere Artikel</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <a href="/got" class="block p-6 bg-white rounded-lg shadow hover:shadow-lg transition">
          <h4 class="font-bold text-lg mb-2 text-primary-600">GOT 2022 Übersicht</h4>
          <p class="text-gray-600 text-sm">Alle wichtigen Informationen zur neuen Gebührenordnung</p>
        </a>
        <a href="/" class="block p-6 bg-white rounded-lg shadow hover:shadow-lg transition">
          <h4 class="font-bold text-lg mb-2 text-primary-600">Kostenrechner</h4>
          <p class="text-gray-600 text-sm">Berechnen Sie die Kosten für Ihren Tierarztbesuch</p>
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
